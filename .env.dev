# Development environment variables for chileneumaticos-webscraping-api
ENVIRONMENT=development
PROJECT_NAME=chileneumaticos-api
SECRET_KEY=dev_secret_change_me
ACCESS_TOKEN_EXPIRE_MINUTES=60

# SQLite will be used in development (no MYSQL_* required)
# Optional: include MySQL vars for parity
MYSQL_HOST=db
MYSQL_PORT=3306
MYSQL_USER=apiuser
MYSQL_PASSWORD=apipassword
MYSQL_DB=chileneumaticos

# Redis (optional)
REDIS_HOST=redis
REDIS_PORT=6379
